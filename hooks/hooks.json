{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/session_marker.py\"",
            "timeout": 10,
            "statusMessage": "dirigent session marker"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Agent|Task|Workflow)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/guard_spawn.py\"",
            "timeout": 10,
            "statusMessage": "dirigent spawn guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/guard_stop.py\"",
            "timeout": 10,
            "statusMessage": "dirigent close guard"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/cleanup.py\"",
            "timeout": 15,
            "statusMessage": "dirigent cleanup"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Agent|Task|Workflow)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/track_spawn.py\"",
            "timeout": 10,
            "statusMessage": "dirigent spawn tracker"
          }
        ]
      }
    ]
  }
}
